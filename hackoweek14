<!doctype html>
<html lang="en" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Printer Queue Management System</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&amp;family=Space+Mono:wght@400;700&amp;display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ['Space Mono', 'monospace'],
            body: ['DM Sans', 'sans-serif']
          }
        }
      }
    }
  </script>
  <style>
    html, body { height: 100%; margin: 0; }
    .queue-arrow { animation: pulseArrow 1.5s ease-in-out infinite; }
    @keyframes pulseArrow { 0%,100%{ opacity:.5; transform:translateX(0) } 50%{ opacity:1; transform:translateX(3px) } }
    @keyframes slideIn { from { opacity:0; transform:translateY(12px) } to { opacity:1; transform:translateY(0) } }
    @keyframes popIn { from { opacity:0; transform:scale(.85) } to { opacity:1; transform:scale(1) } }
    .anim-slide { animation: slideIn .4s ease-out forwards; }
    .anim-pop { animation: popIn .35s ease-out forwards; }
    .job-card-enter { animation: popIn .3s ease-out forwards; }
    @keyframes processOut { to { opacity:0; transform:translateX(-40px) scale(.9); } }
    .job-card-exit { animation: processOut .35s ease-in forwards; }
    .toast-in { animation: slideIn .3s ease-out forwards; }
    @keyframes toastOut { to { opacity:0; transform:translateY(-10px); } }
    .toast-out { animation: toastOut .25s ease-in forwards; }
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
    .noise-bg {
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    }
  </style>
  <style>body { box-sizing: border-box; }</style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
 </head>
 <body class="h-full overflow-auto font-body" style="background-color: #f0f4f8;">
  <div id="app-wrapper" class="w-full min-h-full noise-bg" style="background-color: #f0f4f8;"><!-- Toast Container -->
   <div id="toast-container" class="fixed top-4 right-4 z-50 flex flex-col gap-2"></div><!-- Hero Section -->
   <section id="hero-section" class="relative overflow-hidden">
    <div class="absolute inset-0" style="background: linear-gradient(135deg, #0f2b46 0%, #1a3a5c 40%, #0d4a3a 100%);"></div>
    <div class="absolute inset-0 opacity-10">
     <svg width="100%" height="100%">
      <defs>
       <pattern id="grid" width="40" height="40" patternunits="userSpaceOnUse">
        <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5" />
       </pattern>
      </defs><rect width="100%" height="100%" fill="url(#grid)" />
     </svg>
    </div>
    <div class="relative z-10 max-w-5xl mx-auto px-6 py-20 md:py-28 flex flex-col md:flex-row items-center gap-10">
     <div class="flex-1 text-center md:text-left">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium mb-6" style="background: rgba(52,211,153,0.15); color: #6ee7b7;"><span class="w-2 h-2 rounded-full bg-emerald-400 inline-block"></span> SYSTEM ONLINE
      </div>
      <h1 id="hero-title" class="font-display text-3xl md:text-5xl font-bold text-white leading-tight mb-4">Printer Queue<br>
       Simulator</h1>
      <p id="hero-tagline" class="text-lg md:text-xl mb-8" style="color: #94a3b8;">Manage and process print jobs efficiently</p><button id="cta-btn" onclick="scrollToManager()" class="inline-flex items-center gap-3 px-7 py-3.5 rounded-xl font-semibold text-white transition-all duration-200 hover:scale-105 hover:shadow-lg hover:shadow-emerald-500/20" style="background: linear-gradient(135deg, #10b981, #059669);"> <i data-lucide="layout-dashboard" style="width:20px;height:20px;"></i> <span id="cta-text">Open Queue Manager</span> </button>
     </div>
     <div class="flex-shrink-0">
      <div class="relative w-52 h-52 md:w-64 md:h-64">
       <div class="absolute inset-0 rounded-3xl rotate-6" style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2);"></div>
       <div class="absolute inset-0 rounded-3xl flex items-center justify-center" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(10px);">
        <svg viewbox="0 0 100 100" width="120" height="120"><rect x="20" y="30" width="60" height="35" rx="4" fill="none" stroke="#10b981" stroke-width="2.5" /> <rect x="30" y="15" width="40" height="20" rx="2" fill="none" stroke="#6ee7b7" stroke-width="1.5" opacity="0.7" /> <rect x="25" y="60" width="50" height="8" rx="2" fill="none" stroke="#6ee7b7" stroke-width="1.5" opacity="0.7" /> <rect x="28" y="70" width="44" height="15" rx="2" fill="none" stroke="#34d399" stroke-width="1.5" /> <line x1="32" y1="75" x2="52" y2="75" stroke="#34d399" stroke-width="1" opacity="0.5" /> <line x1="32" y1="79" x2="48" y2="79" stroke="#34d399" stroke-width="1" opacity="0.5" /> <circle cx="70" cy="45" r="3" fill="#10b981">
          <animate attributename="opacity" values="1;0.3;1" dur="2s" repeatcount="indefinite" />
         </circle>
        </svg>
       </div>
      </div>
     </div>
    </div>
   </section><!-- Manager Section -->
   <section id="manager-section" class="max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-16"><!-- Stats Bar -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 mb-8">
     <div class="rounded-xl p-4 border" style="background:#fff; border-color:#e2e8f0;">
      <div class="flex items-center gap-2 mb-1">
       <i data-lucide="layers" style="width:16px;height:16px;color:#3b82f6;"></i><span class="text-xs font-medium" style="color:#64748b;">In Queue</span>
      </div>
      <p id="stat-queue" class="text-2xl font-bold font-display" style="color:#0f172a;">0</p>
     </div>
     <div class="rounded-xl p-4 border" style="background:#fff; border-color:#e2e8f0;">
      <div class="flex items-center gap-2 mb-1">
       <i data-lucide="check-circle" style="width:16px;height:16px;color:#10b981;"></i><span class="text-xs font-medium" style="color:#64748b;">Processed</span>
      </div>
      <p id="stat-processed" class="text-2xl font-bold font-display" style="color:#0f172a;">0</p>
     </div>
     <div class="rounded-xl p-4 border" style="background:#fff; border-color:#e2e8f0;">
      <div class="flex items-center gap-2 mb-1">
       <i data-lucide="file-text" style="width:16px;height:16px;color:#8b5cf6;"></i><span class="text-xs font-medium" style="color:#64748b;">Total Pages</span>
      </div>
      <p id="stat-pages" class="text-2xl font-bold font-display" style="color:#0f172a;">0</p>
     </div>
     <div class="rounded-xl p-4 border" style="background:#fff; border-color:#e2e8f0;">
      <div class="flex items-center gap-2 mb-1">
       <i data-lucide="clock" style="width:16px;height:16px;color:#f59e0b;"></i><span class="text-xs font-medium" style="color:#64748b;">Avg Pages</span>
      </div>
      <p id="stat-avg" class="text-2xl font-bold font-display" style="color:#0f172a;">0</p>
     </div>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6"><!-- Add Job Card -->
     <div class="lg:col-span-1">
      <div class="rounded-2xl border p-6" style="background:#fff; border-color:#e2e8f0;">
       <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg,#3b82f6,#2563eb);"><i data-lucide="plus-circle" style="width:20px;height:20px;color:#fff;"></i>
        </div>
        <div>
         <h2 class="font-display font-bold text-sm" style="color:#0f172a;">Add Print Job</h2>
         <p class="text-xs" style="color:#94a3b8;">Submit a new document</p>
        </div>
       </div>
       <form id="add-form" onsubmit="handleAddJob(event)" class="space-y-4">
        <div><label for="job-id" class="block text-xs font-semibold mb-1.5" style="color:#475569;">Job ID</label> <input id="job-id" type="text" required placeholder="e.g. JOB-001" class="w-full px-3.5 py-2.5 rounded-lg border text-sm outline-none transition-all focus:ring-2" style="border-color:#e2e8f0; background:#f8fafc; color:#0f172a; --tw-ring-color:#3b82f6;">
        </div>
        <div><label for="doc-name" class="block text-xs font-semibold mb-1.5" style="color:#475569;">Document Name</label> <input id="doc-name" type="text" required placeholder="e.g. Annual Report" class="w-full px-3.5 py-2.5 rounded-lg border text-sm outline-none transition-all focus:ring-2" style="border-color:#e2e8f0; background:#f8fafc; color:#0f172a; --tw-ring-color:#3b82f6;">
        </div>
        <div><label for="num-pages" class="block text-xs font-semibold mb-1.5" style="color:#475569;">Number of Pages</label> <input id="num-pages" type="number" min="1" required placeholder="e.g. 25" class="w-full px-3.5 py-2.5 rounded-lg border text-sm outline-none transition-all focus:ring-2" style="border-color:#e2e8f0; background:#f8fafc; color:#0f172a; --tw-ring-color:#3b82f6;">
        </div><button type="submit" class="w-full py-3 rounded-xl font-semibold text-sm text-white transition-all duration-200 hover:scale-[1.02] hover:shadow-lg flex items-center justify-center gap-2" style="background: linear-gradient(135deg,#3b82f6,#2563eb);"> <i data-lucide="send" style="width:16px;height:16px;"></i> Add Print Job </button>
       </form>
      </div><!-- Process Card -->
      <div class="rounded-2xl border p-6 mt-4" style="background:#fff; border-color:#e2e8f0;">
       <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg,#10b981,#059669);"><i data-lucide="printer" style="width:20px;height:20px;color:#fff;"></i>
        </div>
        <div>
         <h2 class="font-display font-bold text-sm" style="color:#0f172a;">Process Jobs</h2>
         <p class="text-xs" style="color:#94a3b8;">FIFO — first in, first out</p>
        </div>
       </div>
       <div id="next-job-preview" class="rounded-lg p-3 mb-4 hidden" style="background:#f0fdf4; border:1px solid #bbf7d0;">
        <p class="text-xs font-medium" style="color:#166534;">Next in queue:</p>
        <p id="next-job-name" class="text-sm font-bold truncate" style="color:#14532d;"></p>
       </div><button id="print-btn" onclick="handleProcessJob()" class="w-full py-3 rounded-xl font-semibold text-sm text-white transition-all duration-200 hover:scale-[1.02] hover:shadow-lg flex items-center justify-center gap-2 disabled:opacity-40 disabled:hover:scale-100" style="background: linear-gradient(135deg,#10b981,#059669);" disabled> <i data-lucide="play" style="width:16px;height:16px;"></i> Print Next Job </button> <button onclick="handleClearAll()" class="w-full py-2.5 rounded-xl font-semibold text-xs mt-2 transition-all duration-200 hover:scale-[1.02] flex items-center justify-center gap-2" style="color:#ef4444; background:#fef2f2; border:1px solid #fecaca;"> <i data-lucide="trash-2" style="width:14px;height:14px;"></i> Clear All Jobs </button>
      </div>
     </div><!-- Queue Table & Visualization -->
     <div class="lg:col-span-2 space-y-6"><!-- Queue Visualization -->
      <div class="rounded-2xl border p-6" style="background:#fff; border-color:#e2e8f0;">
       <div class="flex items-center gap-3 mb-5">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg,#8b5cf6,#7c3aed);"><i data-lucide="git-branch" style="width:20px;height:20px;color:#fff;"></i>
        </div>
        <div>
         <h2 class="font-display font-bold text-sm" style="color:#0f172a;">Queue Visualization</h2>
         <p class="text-xs" style="color:#94a3b8;">Live FIFO pipeline view</p>
        </div>
       </div>
       <div id="viz-container" class="overflow-x-auto pb-2">
        <div id="viz-empty" class="flex items-center justify-center py-8">
         <div class="text-center"><i data-lucide="inbox" style="width:40px;height:40px;color:#cbd5e1;margin:0 auto 8px;display:block;"></i>
          <p class="text-sm" style="color:#94a3b8;">Queue is empty — add a job to see the pipeline</p>
         </div>
        </div>
        <div id="viz-flow" class="hidden items-center gap-1 min-w-max px-2 py-3"></div>
       </div>
      </div><!-- Queue Table -->
      <div class="rounded-2xl border overflow-hidden" style="background:#fff; border-color:#e2e8f0;">
       <div class="flex items-center gap-3 p-6 pb-4">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg,#f59e0b,#d97706);"><i data-lucide="list" style="width:20px;height:20px;color:#fff;"></i>
        </div>
        <div>
         <h2 class="font-display font-bold text-sm" style="color:#0f172a;">Queue Display</h2>
         <p class="text-xs" style="color:#94a3b8;">All print jobs in FIFO order</p>
        </div>
       </div>
       <div class="overflow-x-auto">
        <table class="w-full text-sm">
         <thead>
          <tr style="background:#f8fafc;">
           <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color:#64748b;">#</th>
           <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color:#64748b;">Job ID</th>
           <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color:#64748b;">Document</th>
           <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color:#64748b;">Pages</th>
           <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color:#64748b;">Status</th>
          </tr>
         </thead>
         <tbody id="queue-tbody">
          <tr id="table-empty">
           <td colspan="5" class="px-6 py-12 text-center" style="color:#94a3b8;"><i data-lucide="printer" style="width:32px;height:32px;margin:0 auto 8px;display:block;color:#cbd5e1;"></i> No jobs in queue</td>
          </tr>
         </tbody>
        </table>
       </div><!-- Processed log -->
       <div id="processed-section" class="hidden border-t" style="border-color:#e2e8f0;">
        <div class="px-6 py-3 flex items-center gap-2" style="background:#f8fafc;"><i data-lucide="check-circle" style="width:14px;height:14px;color:#10b981;"></i> <span class="text-xs font-semibold uppercase tracking-wider" style="color:#64748b;">Recently Processed</span>
        </div>
        <div id="processed-list" class="divide-y" style="border-color:#f1f5f9;"></div>
       </div>
      </div>
     </div>
    </div>
   </section>
  </div>
  <script>
  // State
  let queue = [];
  let processed = [];
  let processedCount = 0;
  let totalPagesProcessed = 0;

  const defaultConfig = {
    main_title: 'Printer Queue\nSimulator',
    tagline: 'Manage and process print jobs efficiently',
    cta_button_text: 'Open Queue Manager',
    background_color: '#f0f4f8',
    surface_color: '#ffffff',
    text_color: '#0f172a',
    primary_action_color: '#3b82f6',
    secondary_action_color: '#10b981'
  };

  function applyConfig(config) {
    const c = { ...defaultConfig, ...config };
    const customFont = c.font_family || 'DM Sans';
    const baseSize = c.font_size || 15;

    // Text content
    const title = (c.main_title || defaultConfig.main_title).replace('\\n', '\n');
    document.getElementById('hero-title').innerHTML = title.replace('\n', '<br>');
    document.getElementById('hero-tagline').textContent = c.tagline || defaultConfig.tagline;
    document.getElementById('cta-text').textContent = c.cta_button_text || defaultConfig.cta_button_text;

    // Colors
    const bg = c.background_color || defaultConfig.background_color;
    const surface = c.surface_color || defaultConfig.surface_color;
    const txt = c.text_color || defaultConfig.text_color;
    const primary = c.primary_action_color || defaultConfig.primary_action_color;
    const secondary = c.secondary_action_color || defaultConfig.secondary_action_color;

    document.getElementById('app-wrapper').style.backgroundColor = bg;
    document.body.style.backgroundColor = bg;

    document.querySelectorAll('[style*="background:#fff"]').forEach(el => {
      el.style.background = surface;
    });

    // Font
    document.body.style.fontFamily = `${customFont}, DM Sans, sans-serif`;
    document.querySelectorAll('.font-display').forEach(el => {
      const cf = c.font_family ? `${c.font_family}, ` : '';
      el.style.fontFamily = `${cf}Space Mono, monospace`;
    });

    // Font size
    document.body.style.fontSize = `${baseSize}px`;
  }

  // SDK Init
  if (window.elementSdk) {
    window.elementSdk.init({
      defaultConfig,
      onConfigChange: async (config) => applyConfig(config),
      mapToCapabilities: (config) => ({
        recolorables: [
          { get: () => config.background_color || defaultConfig.background_color, set: v => { config.background_color = v; window.elementSdk.setConfig({ background_color: v }); } },
          { get: () => config.surface_color || defaultConfig.surface_color, set: v => { config.surface_color = v; window.elementSdk.setConfig({ surface_color: v }); } },
          { get: () => config.text_color || defaultConfig.text_color, set: v => { config.text_color = v; window.elementSdk.setConfig({ text_color: v }); } },
          { get: () => config.primary_action_color || defaultConfig.primary_action_color, set: v => { config.primary_action_color = v; window.elementSdk.setConfig({ primary_action_color: v }); } },
          { get: () => config.secondary_action_color || defaultConfig.secondary_action_color, set: v => { config.secondary_action_color = v; window.elementSdk.setConfig({ secondary_action_color: v }); } }
        ],
        borderables: [],
        fontEditable: {
          get: () => config.font_family || defaultConfig.font_family || 'DM Sans',
          set: v => { config.font_family = v; window.elementSdk.setConfig({ font_family: v }); }
        },
        fontSizeable: {
          get: () => config.font_size || defaultConfig.font_size || 15,
          set: v => { config.font_size = v; window.elementSdk.setConfig({ font_size: v }); }
        }
      }),
      mapToEditPanelValues: (config) => new Map([
        ['main_title', config.main_title || defaultConfig.main_title],
        ['tagline', config.tagline || defaultConfig.tagline],
        ['cta_button_text', config.cta_button_text || defaultConfig.cta_button_text]
      ])
    });
  }

  // Toast
  function showToast(message, type = 'success') {
    const container = document.getElementById('toast-container');
    const toast = document.createElement('div');
    const colors = { success: 'background:#10b981;color:#fff;', error: 'background:#ef4444;color:#fff;', info: 'background:#3b82f6;color:#fff;' };
    toast.className = 'toast-in rounded-lg px-4 py-3 text-sm font-medium shadow-lg flex items-center gap-2';
    toast.style.cssText = colors[type] || colors.info;
    const icons = { success: 'check-circle', error: 'alert-circle', info: 'info' };
    toast.innerHTML = `<i data-lucide="${icons[type]}" style="width:16px;height:16px;"></i>${message}`;
    container.appendChild(toast);
    lucide.createIcons();
    setTimeout(() => { toast.className = toast.className.replace('toast-in','toast-out'); setTimeout(() => toast.remove(), 300); }, 2500);
  }

  // Scroll
  function scrollToManager() {
    document.getElementById('manager-section').scrollIntoView({ behavior: 'smooth' });
  }

  // Render
  function render() {
    // Stats
    document.getElementById('stat-queue').textContent = queue.length;
    document.getElementById('stat-processed').textContent = processedCount;
    const totalPages = queue.reduce((s, j) => s + j.pages, 0);
    document.getElementById('stat-pages').textContent = totalPages + totalPagesProcessed;
    const allJobs = processedCount + queue.length;
    document.getElementById('stat-avg').textContent = allJobs ? Math.round((totalPages + totalPagesProcessed) / allJobs) : 0;

    // Print button
    const btn = document.getElementById('print-btn');
    btn.disabled = queue.length === 0;
    const preview = document.getElementById('next-job-preview');
    if (queue.length > 0) {
      preview.classList.remove('hidden');
      document.getElementById('next-job-name').textContent = `${queue[0].id} — ${queue[0].name}`;
    } else {
      preview.classList.add('hidden');
    }

    // Table
    const tbody = document.getElementById('queue-tbody');
    tbody.innerHTML = '';
    if (queue.length === 0) {
      tbody.innerHTML = `<tr><td colspan="5" class="px-6 py-12 text-center" style="color:#94a3b8;"><i data-lucide="printer" style="width:32px;height:32px;margin:0 auto 8px;display:block;color:#cbd5e1;"></i>No jobs in queue</td></tr>`;
    } else {
      queue.forEach((job, i) => {
        const status = i === 0 ? '<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold" style="background:#dbeafe;color:#1d4ed8;"><span class="w-1.5 h-1.5 rounded-full bg-blue-500 inline-block"></span>Next</span>' :
          '<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold" style="background:#f1f5f9;color:#64748b;">Waiting</span>';
        const tr = document.createElement('tr');
        tr.className = 'job-card-enter';
        tr.style.cssText = 'border-top:1px solid #f1f5f9;animation-delay:' + (i * 0.05) + 's;';
        tr.innerHTML = `<td class="px-6 py-3.5 font-medium" style="color:#94a3b8;">${i + 1}</td><td class="px-6 py-3.5 font-bold font-display text-xs" style="color:#0f172a;">${job.id}</td><td class="px-6 py-3.5" style="color:#334155;">${job.name}</td><td class="px-6 py-3.5 font-display text-xs" style="color:#334155;">${job.pages}</td><td class="px-6 py-3.5">${status}</td>`;
        tbody.appendChild(tr);
      });
    }

    // Processed log
    const pSection = document.getElementById('processed-section');
    const pList = document.getElementById('processed-list');
    if (processed.length > 0) {
      pSection.classList.remove('hidden');
      pList.innerHTML = '';
      processed.slice(-5).reverse().forEach(job => {
        const div = document.createElement('div');
        div.className = 'px-6 py-3 flex items-center justify-between text-xs anim-slide';
        div.innerHTML = `<div class="flex items-center gap-3"><i data-lucide="check" style="width:14px;height:14px;color:#10b981;"></i><span class="font-bold font-display" style="color:#64748b;">${job.id}</span><span style="color:#94a3b8;">${job.name}</span></div><span class="font-display" style="color:#94a3b8;">${job.pages}p</span>`;
        pList.appendChild(div);
      });
    } else {
      pSection.classList.add('hidden');
    }

    // Visualization
    const vizEmpty = document.getElementById('viz-empty');
    const vizFlow = document.getElementById('viz-flow');
    if (queue.length === 0) {
      vizEmpty.classList.remove('hidden');
      vizFlow.classList.add('hidden');
      vizFlow.classList.remove('flex');
    } else {
      vizEmpty.classList.add('hidden');
      vizFlow.classList.remove('hidden');
      vizFlow.classList.add('flex');
      vizFlow.innerHTML = '';
      // Front label
      const front = document.createElement('div');
      front.className = 'flex-shrink-0 px-3 py-1.5 rounded-lg text-xs font-bold font-display';
      front.style.cssText = 'background:#dbeafe;color:#1d4ed8;';
      front.textContent = 'FRONT';
      vizFlow.appendChild(front);

      queue.forEach((job, i) => {
        // Arrow
        const arrow = document.createElement('div');
        arrow.className = 'queue-arrow flex-shrink-0';
        arrow.innerHTML = '<svg width="24" height="16" viewBox="0 0 24 16"><path d="M0 8h18M14 3l6 5-6 5" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        vizFlow.appendChild(arrow);
        // Card
        const card = document.createElement('div');
        card.className = 'flex-shrink-0 rounded-xl p-3 anim-pop';
        card.style.cssText = `border:2px solid ${i === 0 ? '#3b82f6' : '#e2e8f0'};background:${i === 0 ? '#eff6ff' : '#fff'};min-width:100px;animation-delay:${i * 0.08}s;`;
        card.innerHTML = `<p class="font-display text-xs font-bold truncate" style="color:#0f172a;max-width:90px;">${job.id}</p><p class="text-xs truncate mt-0.5" style="color:#64748b;max-width:90px;">${job.name}</p><p class="text-xs font-display mt-1" style="color:#94a3b8;">${job.pages}p</p>`;
        vizFlow.appendChild(card);
      });

      // Rear
      const arrowR = document.createElement('div');
      arrowR.className = 'queue-arrow flex-shrink-0';
      arrowR.innerHTML = '<svg width="24" height="16" viewBox="0 0 24 16"><path d="M0 8h18M14 3l6 5-6 5" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
      vizFlow.appendChild(arrowR);
      const rear = document.createElement('div');
      rear.className = 'flex-shrink-0 px-3 py-1.5 rounded-lg text-xs font-bold font-display';
      rear.style.cssText = 'background:#f1f5f9;color:#64748b;';
      rear.textContent = 'REAR';
      vizFlow.appendChild(rear);
    }

    lucide.createIcons();
  }

  // Handlers
  function handleAddJob(e) {
    e.preventDefault();
    const id = document.getElementById('job-id').value.trim();
    const name = document.getElementById('doc-name').value.trim();
    const pages = parseInt(document.getElementById('num-pages').value);
    if (!id || !name || !pages) return;
    if (queue.some(j => j.id === id)) { showToast('Duplicate Job ID!', 'error'); return; }
    queue.push({ id, name, pages });
    document.getElementById('add-form').reset();
    showToast(`Added "${name}" to queue`, 'success');
    render();
  }

  function handleProcessJob() {
    if (queue.length === 0) return;
    const job = queue.shift();
    processed.push(job);
    processedCount++;
    totalPagesProcessed += job.pages;
    showToast(`Printing "${job.name}" (${job.pages} pages)`, 'info');
    render();
  }

  function handleClearAll() {
    if (queue.length === 0) { showToast('Queue is already empty', 'info'); return; }
    queue = [];
    showToast('Queue cleared', 'info');
    render();
  }

  // Init
  render();
  lucide.createIcons();
</script>
